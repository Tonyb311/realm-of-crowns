{
  "name": "@realm-of-crowns/database",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "migrate": "drizzle-kit generate --config=drizzle.config.ts",
    "migrate:push": "drizzle-kit push --config=drizzle.config.ts",
    "migrate:deploy": "drizzle-kit migrate --config=drizzle.config.ts",
    "seed": "tsx --require tsconfig-paths/register seeds/index.ts",
    "studio": "drizzle-kit studio --config=drizzle.config.ts",
    "introspect": "drizzle-kit introspect --config=drizzle.config.ts",
    "validate-sync": "tsx --tsconfig tsconfig.json scripts/validate-yaml-sync.ts",
    "build:schema": "tsc -p tsconfig.schema.json"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.18.0",
    "js-yaml": "^4.1.1",
    "tsx": "^4.15.0",
    "typescript": "^5.9.0"
  }
}
